  "version": "0.0.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev:backend": "pnpm --filter backend dev",
    "dev:storefront": "pnpm --filter storefront-apollo dev",
    "dev:relay": "pnpm --filter storefront-relay dev",
