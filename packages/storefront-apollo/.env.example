# .env.example — copy to .env and fill in values before running the storefront.
# Vite only exposes variables prefixed with VITE_ to client-side code.

# Full URL of the Vendure Shop API GraphQL endpoint.
# In development this points to the local backend; override in .env for staging/prod.
VITE_VENDURE_SHOP_API_URL=http://localhost:3000/shop-api
