# .env.example — copy to .env and fill in values before starting the server.
# Never commit .env to version control; this file is safe to commit.

# Runtime environment. Controls behaviour like error verbosity and latency simulation.
APP_ENV=development

# Artificial delay added to every Shop API response (ms). Useful for simulating
# real-world network conditions while developing the storefront locally.
SIMULATED_LATENCY_MS=600

# Port the Vendure server listens on.
PORT=3000

# Secret used to sign session cookies. Must be a long random string in production.
COOKIE_SECRET=change-me-in-production

# Vendure admin superuser credentials — used only on first boot to seed the admin.
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=superadmin123

# Set to 'postgres' for production (Render, Railway, etc.).
# Vendure ships a SQLite adapter (better-sqlite3) which is fine for local dev.
DB_TYPE=better-sqlite3

# The four vars below are only used when DB_TYPE=postgres — leave blank for SQLite.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vendure
DB_USERNAME=postgres
DB_PASSWORD=
